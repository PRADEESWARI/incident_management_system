# Application
APP_NAME=IncidentManagementSystem
APP_ENV=development
DEBUG=true
SECRET_KEY=super-secret-jwt-key-change-in-production-min-32-chars
API_KEY_HEADER=X-API-Key
SIGNAL_API_KEY=signal-ingestion-api-key-2024

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ims_db
POSTGRES_USER=ims_user
POSTGRES_PASSWORD=ims_password
DATABASE_URL=postgresql+asyncpg://ims_user:ims_password@postgres:5432/ims_db

# MongoDB
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=ims_signals
MONGO_USER=ims_user
MONGO_PASSWORD=ims_password
MONGO_URL=mongodb://ims_user:ims_password@mongodb:27017/ims_signals

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ims_redis_password
REDIS_URL=redis://:ims_redis_password@redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SIGNAL_TOPIC=ims.signals
KAFKA_INCIDENT_TOPIC=ims.incidents
KAFKA_ALERT_TOPIC=ims.alerts
KAFKA_DLQ_TOPIC=ims.dlq

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Rate Limiting
RATE_LIMIT_SIGNALS=10000/minute
RATE_LIMIT_API=1000/minute

# Debounce
DEBOUNCE_WINDOW_SECONDS=10
DEBOUNCE_THRESHOLD=5

# Escalation
ESCALATION_P2_TO_P1_MINUTES=15
ESCALATION_P1_TO_P0_MINUTES=10

# Slack Integration (optional)
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# Frontend URL
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:80
